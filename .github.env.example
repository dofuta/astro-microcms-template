# Copy this file to .github.env and fill in the values locally.
# Do not commit .github.env.

# Classic PAT with repo scope and push access to the target repository.
SYNC_TARGET_TOKEN=replace_with_classic_pat

# Target repository in owner/repo format.
SYNC_TARGET_REPO=dofuta/target-repo

# Optional. Defaults to main when omitted.
SYNC_TARGET_BRANCH=main

